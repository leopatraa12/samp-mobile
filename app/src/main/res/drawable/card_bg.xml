<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fundo principal -->
    <solid android:color="#1A000000"/>

    <!-- Borda suave -->
    <stroke
        android:width="1dp"
        android:color="#33FFFFFF"/>

    <!-- Cantos arredondados -->
    <corners android:radius="16dp"/>

    <!-- Padding interno visual -->
    <padding
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp"/>

</shape>